class Solution {
    public static void pb(ArrayDeque<Integer> dq, int x) {
        
        dq.addLast(x);
        
    }

    public static void ppb(ArrayDeque<Integer> dq) {
        
        if(!dq.isEmpty()){
            dq.removeLast();
        }
    }

        
    public static int front_dq(ArrayDeque<Integer> dq) {
       if (dq.isEmpty()) {
            return -1;
        }
        return dq.peekFirst();
    }
        

    public static void pf(ArrayDeque<Integer> dq, int x) {
        dq.addFirst(x);
    }
}
