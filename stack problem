class Solution{
    static Stack<Integer> deleteMid(int n, Stack<Integer> st)
    {
        int mid = n/2;
        
         deleteMiddleHelper(st, mid);
         
         return st;
    }
    
    static void  deleteMiddleHelper(Stack<Integer>st, int mid){
        
        if(mid == 0){
            st.pop();
            return;
        }
        
         int top = st.pop();
         
          deleteMiddleHelper(st, mid - 1);
          
          st.push(top);
    }
}
