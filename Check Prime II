import java.util.*;

public class Solution {
    public static void main(String args[]) {
        
        Scanner scanner = new Scanner(System.in);
        
        int n = scanner.nextInt();
        
        if(n<=1){
            System.out.println("False");
        }
        
        for(int i = 2; i*i<=n;i++){
            
            if(n%i == 0){
                System.out.println("False");
                return;
            }
        }
            System.out.println("True");
    }
}
